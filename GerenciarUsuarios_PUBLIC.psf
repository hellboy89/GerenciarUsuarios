$buttonAbrirPasta_Click={
	#TODO: Place custom script here
	if ([string]::IsNullOrEmpty($listboxListarServidores.Text))
	{
		$BarraStatus.Text = "Precisa INFORMAR o SERVIDOR!"
		return
	}
	
	if ([string]::IsNullOrEmpty($listboxParticoes.Text))
	{
		$BarraStatus.Text = "Precisa INFORMAR a PARTIÇÃO!"
		return
	}
	
	$pegaServidor = $listboxListarServidores.Text.ToString()
	$pegaPart = $listboxParticoes.Text.ToString()
	
	$dirCompleto = "\\" + $pegaServidor + "\" + $pegaPart + "$"
	
	$verificaLocal = Test-Path -Path $dirCompleto
	
	if ($verificaLocal)
	{
		explorer "$dirCompleto"
	}
	else
	{
		$BarraStatus = "Local INEXISTENTE, verifique a unidade CORRETA!"
	}
}

$listboxListarServidores_SelectedIndexChanged={
	#TODO: Place custom script here
	$listboxParticoes.Items.Clear()
	
	$hostname = $listboxListarServidores.Text.ToString()
	
	# Obtém as informações das partições
	$particoes = Get-CimInstance -ClassName Win32_LogicalDisk -ComputerName $hostname
	
	# Exibe as informações de cada partição
	$particoes | ForEach-Object {
		$listarPart = $_.DeviceID -replace ":", ""
		$listboxParticoes.Items.Add($listarPart)
	}
	
}

