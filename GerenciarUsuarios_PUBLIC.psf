$ListaUsuariosTSApp2_Click = {
	$usuarios = $ListaUsuariosTSApp2.SelectedItems
	
	$ListaGruposAtuais.Items.Clear()
	
	if ($usuarios.Count -gt 0)
	{
		$gruposComuns = $null
		
		foreach ($usuario in $usuarios)
		{
			$memberOf = (Get-ADUser -Identity $usuario -Server 127.0.0.1 -Properties MemberOf).MemberOf
			$gruposUsuario = ($memberOf | ForEach-Object { ($_ -split ',')[0] -replace 'CN=', '' } | Sort-Object)
			
			if ($null -eq $gruposComuns)
			{
				$gruposComuns = $gruposUsuario
			}
			else
			{
				$gruposComuns = $gruposComuns | Where-Object { $gruposUsuario -contains $_ }
			}
		}
		
		foreach ($grupo in $gruposComuns)
		{
			$ListaGruposAtuais.Items.Add($grupo)
		}
		
		$labelBuscaUsuariosTSapp.Text = "Busca Usuários"
		$labelBuscaUsuariosTSapp.ForeColor = "Blue"
		$BuscaUsuariosTSapp.Text = ""
		$BarraStatus.Text = "Listado Grupo do Usuario: $usuarios"
	}
}

function atualizaPermissaoUsuarios()
{
	$usuarios = if ($ListaUsuariosTSApp2.SelectedItems.Count -gt 0)
	{
		$ListaUsuariosTSApp2.SelectedItems
	}
	else
	{
		@($BuscaUsuariosTSapp.Text)
	}
	
	$ListaGruposAtuais.Items.Clear()
	$gruposComuns = $null
	
	foreach ($usuario in $usuarios)
	{
		# Substituído Get-ADPrincipalGroupMembership por MemberOf
		$memberOf = (Get-ADUser -Identity $usuario -Server 127.0.0.1 -Properties MemberOf).MemberOf
		$gruposUsuario = ($memberOf | ForEach-Object { ($_ -split ',')[0] -replace 'CN=', '' } | Sort-Object)
		
		if ($null -eq $gruposComuns)
		{
			$gruposComuns = $gruposUsuario
		}
		else
		{
			$gruposComuns = $gruposComuns | Where-Object { $gruposUsuario -contains $_ }
		}
	}
	
	foreach ($grupo in $gruposComuns)
	{
		$ListaGruposAtuais.Items.Add($grupo)
	}
}

$RemoverGrupoTSApp_Click = {
	#TODO: Place custom script here
	$usuario = $ListaUsuariosTSApp2.SelectedItems
	$grupo = $ListaGruposAtuais.SelectedItems
	
	foreach ($listarUsuarios in $Usuario)
	{
		if ($listarUsuarios)
		{
			foreach ($listar in $grupo)
			{
				Remove-ADPrincipalGroupMembership -Identity $listarUsuarios -MemberOf $listar -Confirm:$false
				
			}
			
			$BarraStatus.Text = "Removido Permissão!"
		}
		else
		{
			foreach ($listar in $grupo)
			{
				Remove-ADPrincipalGroupMembership -Identity $global:usuarioSelecionadoTsApp -MemberOf $listar -Confirm:$false
				
			}
			
			$BarraStatus.Text = "Removido Permissão!"
		}
	}
	
	
	atualizaPermissaoUsuarios
}

$AdicionarGrupoTsAPP_Click = {
	$usuarios = $ListaUsuariosTSApp2.SelectedItems
	$grupoTodosEsc = $ListaGruposTSApp.SelectedItems
	
	$listaUsuariosFinal = if ($usuarios.Count -gt 0) { $usuarios }
	else { @($global:usuarioSelecionadoTsApp) }
	
	# Adiciona todos os usuários de uma vez por grupo (muito mais rápido)
	foreach ($listar in $grupoTodosEsc)
	{
		Add-ADGroupMember -Identity $listar -Members $listaUsuariosFinal -Server 127.0.0.1
	}
	
	$BarraStatus.Text = "Adicionado Permissão!"
	
	# Fora do loop - executa apenas UMA vez no final
	atualizaPermissaoUsuarios
	
	$ListaGruposTSApp.ClearSelected()
}

