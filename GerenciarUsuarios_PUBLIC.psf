function verificaStatusLigadoInstancia($ocid)
{
	$env:SUPPRESS_LABEL_WARNING = "True"
	$statusInstancia = oci compute instance get --instance-id $ocid --query data.\`"lifecycle-state\`" --raw-output
	
	if ($statusInstancia -like "*RUNNING*")
	{
		$textboxStatusInstancia.Text = "LIGADO"
		$textboxStatusInstancia.BackColor = 'GreenYellow'
	}
	else
	{
		$textboxStatusInstancia.Text = "DESLIGADO"
		$textboxStatusInstancia.BackColor = 'Salmon'
	}
	
}

function verificaStatusOCIDInstancia($ocid)
{
	oci compute instance get --instance-id $ocid > $null 2>$null
	
	if ($LASTEXITCODE -eq 0)
	{
		$textboxStatusOCID.Text = "Instância EXISTE"
		$textboxStatusOCID.BackColor = 'GreenYellow'
	}
	else
	{
		$textboxStatusOCID.Text = "Instância NÃO existe confira o OCID se está correto"
		$textboxStatusOCID.BackColor = 'Salmon'
	}
	
}

$listboxListaServidores_SelectedIndexChanged={
	#TODO: Place custom script here
	$nomeBusca = $listboxListaServidores.Text.ToString()
	$linha = Get-Content "C:\script\LiberaPermissaoPreenchimento\servidoresOracleOCID.txt" | Where-Object { $_ -match "^$nomeBusca\s*=" }
	
	if ($linha)
	{
		$ocid = ($linha -split " = ", 2)[1].Trim('"').Trim()
		$textboxMostraOCID.Text = $ocid
	}
	else
	{
		"Nome '$nomeBusca' não encontrado."
	}
	
	abrirNotificacaoEspera "Carregando Status, aguarde!..."
	verificaStatusLigadoInstancia $ocid
	verificaStatusOCIDInstancia $ocid
	fecharNotificacaoEspera
}

$buttonLigarInstancia_Click={
	#TODO: Place custom script here
	
	if (! $listboxListaServidores.Text.ToString())
	{
		mensagemAlerta "Precisa selecionar uma INSTÂNCIA!"
		return
	}
	
	$ocid = $textboxMostraOCID.Text.ToString()
	
	abrirNotificacaoEspera "Enviando comando, aguarde!"
	oci compute instance action --instance-id $ocid --action START
	fecharNotificacaoEspera
	
	mensagemAlerta "Comando enviado com sucesso, aguarde o processo de INICIAR!"
}

