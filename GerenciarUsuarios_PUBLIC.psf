$BuscaUsuariosTSapp_TextChanged = {
	#TODO: Place custom script here
	$usuarioBuscado = $BuscaUsuariosTSapp.Text
	
	$buscaUsuarioVar = (Get-AdUser -SearchBase "$global:pegaOuUsuarios" -Filter { SamAccountName -eq $usuarioBuscado } -SearchScope Subtree).SamAccountName

	if (! $usuarioBuscado)
	{
		$labelBuscaUsuariosTSapp.Text = "Busca Usuários"
		$labelBuscaUsuariosTSapp.ForeColor = "Blue"
	}
	
	if ($buscaUsuarioVar)
	{
		$labelBuscaUsuariosTSapp.Text = "Usuário ENCONTRADO!"
		$labelBuscaUsuariosTSapp.ForeColor = "Blue"
		$ListaUsuariosTSApp2.ClearSelected()
		$ListaGruposAtuais.Items.Clear()
		$global:usuarioSelecionadoTsApp = $buscaUsuarioVar
		
		$gruposUsuario = (Get-ADPrincipalGroupMembership -Identity $buscaUsuarioVar | Sort-Object -Property name).name
		
		foreach ($listar in $gruposUsuario)
		{
			$ListaGruposAtuais.Items.Add($listar)
		}
		
	}
	else
	{
		$labelBuscaUsuariosTSapp.Text = "Usuário NÃO encontrado!"
		$labelBuscaUsuariosTSapp.ForeColor = "Red"
	}
}

$BuscaUsuario_TextChanged = {
	#TODO: Place custom script here
	$usuarioBuscado = $BuscaUsuario.Text

	$buscaUsuarioVar = (Get-AdUser -SearchBase "$global:pegaOuUsuarios" -Filter { SamAccountName -eq $usuarioBuscado } -SearchScope Subtree).SamAccountName

	$mostraOUNome = ((Get-ADUser -Identity $buscaUsuarioVar).DistinguishedName -split ',')[1] -replace 'OU=', ''
	
	$labelMostraEmpresa.Text = $mostraOUNome
	
	if (! $usuarioBuscado)
	{
		$labelBuscaUsuario.Text = "Busca Usuários"
		$labelBuscaUsuario.ForeColor = "Blue"
	}
	else
	{
		if ($buscaUsuarioVar)
		{
			$labelBuscaUsuario.Text = "Usuário ENCONTRADO!"
			$labelBuscaUsuario.ForeColor = "Blue"
			$global:usuarioSelecionado = $buscaUsuarioVar
			
			&$mostraServidorUsuario
		}
		else
		{
			$labelBuscaUsuario.Text = "Usuário NÃO encontrado!"
			$labelBuscaUsuario.ForeColor = "Red"
		}
		
		# ================================================================
		
		$DescricaoUsuario.Text = (Get-ADUser -Identity $global:usuarioSelecionado -Properties Description).Description
		
		$usuariosBloqueados = (Search-ADAccount -LockedOut).SamAccountName
		
		if ($usuariosBloqueados -eq $global:usuarioSelecionado)
		{
			$StatusUsuarioAD.Text = "Usuário Bloqueado, por tentativas de senha!"
		}
		else
		{
			$statusDesativado = (Get-ADUser -Identity $global:usuarioSelecionado).Enabled
			
			if ($statusDesativado -like "False")
			{
				$StatusUsuarioAD.Text = "Usuário Desativado pelo Administrador."
			}
			else
			{
				$StatusUsuarioAD.Text = "OK"
			}
		}
		
		$infoStatusLastLogon = (Get-ADUser -Identity $global:usuarioSelecionado -Properties LastLogon | Select Name, @{ Name = 'LastLogon'; Expression = { [DateTime]::FromFileTime($_.LastLogon) } }).LastLogon
		$valorConvertido = $infoStatusLastLogon.ToString("dd/MM/yyyy HH:mm")
		
		if ($valorConvertido -like "*1600*")
		{
			$labelUltimoLogon.Text = "NUNCA USOU!"
		}
		else
		{
			$labelUltimoLogon.Text = $valorConvertido
		}
	}
	
	
	
}

