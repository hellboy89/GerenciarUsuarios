$ListaUsuariosOUs_Click = {
	#TODO: Place custom script here
	$Usuario = $ListaUsuariosOUs.SelectedItem.ToString()
	
	$DescricaoUsuario.Text = (Get-ADUser -Identity $Usuario -Properties Description).Description
	
	$usuariosBloqueados = (Search-ADAccount -LockedOut).SamAccountName
	
	if ($usuariosBloqueados -eq $Usuario)
	{
		$StatusUsuarioAD.Text = "Usuário Bloqueado, por tentativas de senha!"
	}
	else
	{
		$statusDesativado = (Get-ADUser -Identity $Usuario).Enabled
		
		if ($statusDesativado -like "False")
		{
			$StatusUsuarioAD.Text = "Usuário Desativado pelo Administrador."
		}
		else
		{
			$StatusUsuarioAD.Text = "OK"
		}
	}
	
	$infoStatusLastLogon = (Get-ADUser -Identity $Usuario -Properties LastLogon | Select Name, @{ Name = 'LastLogon'; Expression = { [DateTime]::FromFileTime($_.LastLogon) } }).LastLogon
	$valorConvertido = $infoStatusLastLogon.ToString("dd/MM/yyyy HH:mm")
	
	if ($valorConvertido -like "*1600*")
	{
		$labelUltimoLogon.Text = "NUNCA USOU!"
	}
	else
	{
		$labelUltimoLogon.Text = $valorConvertido
	}
	
	$mostraOUNome = ((Get-ADUser -Identity $Usuario).DistinguishedName -split ',')[1] -replace 'OU=', ''
	
	$labelMostraEmpresa.Text = $mostraOUNome
	
	&$mostraServidorUsuario
}

$ListaOUs_SelectedValueChanged = {
	#TODO: Place custom script here
	$BuscaUsuario.Text = ""
	$label_NomeServidor.Text = "mostra aqui!"
	$ouEscolhida = $ListaOUs.SelectedItem.ToString()
	$ListaUsuariosOUs.SelectedItems
	
	$ListaUsuariosOUs.Items.Clear()
	
	$ListaUsuarios = (Get-AdUser -SearchBase "OU=$ouEscolhida,$global:pegaOuUsuarios" -Filter * -SearchScope OneLevel).SamAccountName

	foreach ($listar in $ListaUsuarios)
	{
		$ListaUsuariosOUs.Items.Add($listar)
	}
	
	# &$mostraServidorUsuario
}

$mostraServidorUsuario = {
	if ($ListaUsuariosOUs.SelectedItems)
	{
		$Usuario = ($ListaUsuariosOUs.SelectedItems)[0]
	}
	else
	{
		$Usuario = $BuscaUsuario.Text
	}
	
	# Muito mais rápido que Get-ADPrincipalGroupMembership
	$memberOf = (Get-ADUser -Identity $Usuario -Server 127.0.0.1 -Properties MemberOf).MemberOf
	$grupo = ($memberOf | ForEach-Object { ($_ -split ',')[0] -replace 'CN=', '' } | Where-Object { $_ -like "*_users_*" })
	
	if ($grupo -is [string])
	{
		$usuarioEsc = (Get-ADObject -Filter "objectclass -eq 'group' -and name -like '$grupo'" -Properties info -Server 127.0.0.1 | Select-Object info).info
		$label_NomeServidor.Text = $usuarioEsc
	}
	elseif ($null -eq $grupo)
	{
		$label_NomeServidor.Text = "Sem Servidor"
	}
	else
	{
		$label_NomeServidor.Text = "Diversos Servidores"
	}
}

$DesbloquearUsuario = {
	#TODO: Place custom script here
	$Usuario = $ListaUsuariosOUs.SelectedItems
	
	if ($Usuario)
	{
		foreach ($listar in $Usuario)
		{
			Unlock-ADAccount -Identity $listar
		}
	}
	else
	{
		Unlock-ADAccount -Identity $global:usuarioSelecionado
	}
	
}

$SenhaPadrao_Click = {
	#TODO: Place custom script here
	
	$Usuario = $ListaUsuariosOUs.SelectedItems
	
	# CONDICAO PREENCHER PLANILHA ================================
	
	if ([string]::IsNullOrEmpty($textboxNomeSolicitante.Text))
	{
		$BarraStatus.Text = "Precisa INFORMAR o SOLICITANTE!"
		return
	}
	
	if (($radiobuttonSolExterno.Checked -eq $false) -and ($radiobuttonSolInterno.Checked -eq $false))
	{
		$BarraStatus.Text = "Precisa INFORMAR se o SOLICITANTE e INTERNO ou EXTERNO!"
		return
	}
	
	if ($radiobuttonSolInterno.Checked)
	{
		$pegarNomeEmpresaUsuario = "Empresa"
		$formaSolicitacao = "Chat Google"
	}
	else
	{
		$pegaEmpresa = (($labelMostraEmpresa.Text) -split "-")[0]
		$pegarNomeEmpresaUsuario = ($pegaEmpresa.Substring(0, 1).ToUpper() + $pegaEmpresa.Substring(1).ToLower())
		$formaSolicitacao = "Blip"
	}
	
	$pegaEmpresaOU = (($labelMostraEmpresa.Text) -split "-")[0]
	$pegarNomeOU = ($pegaEmpresaOU.Substring(0, 1).ToUpper() + $pegaEmpresaOU.Substring(1).ToLower())
	
	# ========================================================
	
	if ($Usuario)
	{
		foreach ($listar in $Usuario)
		{
			$senha = ConvertTo-SecureString "Mudar@123" -AsPlainText -Force
			Set-ADAccountPassword -Identity $listar -NewPassword $senha -Reset
			Set-ADUser -Identity $listar -ChangePasswordAtLogon $true -PasswordNeverExpires $false -CannotChangePassword $false
			
			$BarraStatus.Text = "Senha resetada do $listar para Mudar@123. Mudar no acesso!"
			$StatusUsuarioAD.Text = "OK"
			
			Set-ADUser -Identity $listar -Description " "
			
			$DescricaoUsuario.Text = (Get-ADUser -Identity $listar -Properties Description).Description
		}
		
		preencherGooglePlan2 $textboxNomeSolicitante.Text $pegarNomeEmpresaUsuario $pegarNomeOU $formaSolicitacao
		
		limparCamposObrigatoriosSenha
	}
	else
	{
		$senha = ConvertTo-SecureString "Mudar@123" -AsPlainText -Force
		Set-ADAccountPassword -Identity $global:usuarioSelecionado -NewPassword $senha -Reset
		Set-ADUser -Identity $global:usuarioSelecionado -ChangePasswordAtLogon $true -PasswordNeverExpires $false -CannotChangePassword $false
		
		$BarraStatus.Text = "Senha alterada do $global:usuarioSelecionado para Mudar@123. Mudar no acesso!"
		$StatusUsuarioAD.Text = "OK"
		
		Set-ADUser -Identity $global:usuarioSelecionado -Description " "
		
		preencherGooglePlan2 $textboxNomeSolicitante.Text $pegarNomeEmpresaUsuario $pegarNomeOU $formaSolicitacao
		
		$DescricaoUsuario.Text = (Get-ADUser -Identity $global:usuarioSelecionado -Properties Description).Description
		
		limparCamposObrigatoriosSenha
	}
	
	& $DesbloquearUsuario
}

$SenhaManual_Click = {
	#TODO: Place custom script here
	# . "C:\Users\admin.usuario\Documents\PowerShell_Scripts\_TESTES\teste72_liberaPermissaoGUI\PegarSenha.psf" NÃO FUNCIONA
	
	$Usuario = $ListaUsuariosOUs.SelectedItems
	
	# CONDICAO PREENCHER PLANILHA ================================
	
	if ([string]::IsNullOrEmpty($textboxNomeSolicitante.Text))
	{
		$BarraStatus.Text = "Precisa INFORMAR o SOLICITANTE!"
		return
	}
	
	if (($radiobuttonSolExterno.Checked -eq $false) -and ($radiobuttonSolInterno.Checked -eq $false))
	{
		$BarraStatus.Text = "Precisa INFORMAR se o SOLICITANTE e INTERNO ou EXTERNO!"
		return
	}
	
	if ($radiobuttonSolInterno.Checked)
	{
		$pegarNomeEmpresaUsuario = "Empresa"
		$formaSolicitacao = "Chat Google"
	}
	else
	{
		$pegaEmpresa = (($labelMostraEmpresa.Text) -split "-")[0]
		$pegarNomeEmpresaUsuario = ($pegaEmpresa.Substring(0, 1).ToUpper() + $pegaEmpresa.Substring(1).ToLower())
		$formaSolicitacao = "Blip"
	}
	
	$pegaEmpresaOU = (($labelMostraEmpresa.Text) -split "-")[0]
	$pegarNomeOU = ($pegaEmpresaOU.Substring(0, 1).ToUpper() + $pegaEmpresaOU.Substring(1).ToLower())
	
	# ========================================================
	
	if ($Usuario)
	{
		foreach ($listar in $Usuario)
		{
			
			$SenhaDigitada = $DigitaSenha.Text
			
			$StatusUsuarioAD.Text = $textoDigitado
			
			$senha = ConvertTo-SecureString $SenhaDigitada -AsPlainText -Force
			Set-ADAccountPassword -Identity $listar -NewPassword $senha -Reset
			
			
			if ($FixarSenha.Checked)
			{
				Set-ADUser -Identity $listar -ChangePasswordAtLogon $false -PasswordNeverExpires $true
				
				Set-ADUser -Identity $listar -Description "Senha - $SenhaDigitada"
				
				$BarraStatus.Text = "Senha resetada do $listar para $SenhaDigitada. E Fixada!"
				
				$DescricaoUsuario.Text = (Get-ADUser -Identity $listar -Properties Description).Description
			}
			else
			{
				Set-ADUser -Identity $listar -PasswordNeverExpires $false -ChangePasswordAtLogon $true
				
				Set-ADUser -Identity $listar -Description " "
				
				$BarraStatus.Text = "Senha resetada do $listar para $SenhaDigitada. Mudar no acesso!"
				
				$DescricaoUsuario.Text = (Get-ADUser -Identity $listar -Properties Description).Description
			}
		}
		
		preencherGooglePlan2 $textboxNomeSolicitante.Text $pegarNomeEmpresaUsuario $pegarNomeOU $formaSolicitacao
		
		limparCamposObrigatoriosSenha
	}
	else
	{
		$SenhaDigitada = $DigitaSenha.Text
		
		$BarraStatus.Text = $textoDigitado
		
		$senha = ConvertTo-SecureString $SenhaDigitada -AsPlainText -Force
		Set-ADAccountPassword -Identity $global:usuarioSelecionado -NewPassword $senha -Reset
		
		
		if ($FixarSenha.Checked)
		{
			Set-ADUser -Identity $global:usuarioSelecionado -ChangePasswordAtLogon $false -PasswordNeverExpires $true
			
			Set-ADUser -Identity $global:usuarioSelecionado -Description "Senha - $SenhaDigitada"
			
			$BarraStatus.Text = "Senha Alterada do $global:usuarioSelecionado para $SenhaDigitada. E Fixada!"		
			
			$DescricaoUsuario.Text = (Get-ADUser -Identity $global:usuarioSelecionado -Properties Description).Description
		}
		else
		{
			Set-ADUser -Identity $global:usuarioSelecionado -PasswordNeverExpires $false -ChangePasswordAtLogon $true
			
			Set-ADUser -Identity $global:usuarioSelecionado -Description " "
			
			$BarraStatus.Text = "Senha Alterada do $global:usuarioSelecionado para $SenhaDigitada. Mudar no acesso!"
			
			$DescricaoUsuario.Text = (Get-ADUser -Identity $global:usuarioSelecionado -Properties Description).Description
		}
		
		preencherGooglePlan2 $textboxNomeSolicitante.Text $pegarNomeEmpresaUsuario $pegarNomeOU $formaSolicitacao
		
		limparCamposObrigatoriosSenha
	}
	
	& $DesbloquearUsuario
	$StatusUsuarioAD.Text = "OK"
	$FixarSenha.Checked = $false
	$DigitaSenha.Clear()
}

function limparCamposObrigatoriosSenha()
{
	$textboxNomeSolicitante.Text = ""
	$radiobuttonSolExterno.Checked = $false
	$radiobuttonSolInterno.Checked = $false
}

