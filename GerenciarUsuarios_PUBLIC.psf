$buttonConectarTS_Click={
	#TODO: Place custom script here
	if ($listboxListarServidores.SelectedIndex -eq -1)
	{
		mensagemAlerta "Precisa selecionar um SERVIDOR!"
		return
	}
	
	if (! $textboxNomeUsuario.Text.ToString())
	{
		mensagemAlerta "Precisa informar o USUARIO!"
		return
	}
	
	if (! $textboxSenhaUsuario.Text.ToString())
	{
		mensagemAlerta "Precisa informar a SENHA!"
		return
	}
	
	# selecionar o servidor
	
	$hostname = $listboxListarServidores.Text.ToString().Replace("SRV", "")
	$soHost = $listboxListarServidores.Text.ToString()
	
	$selecionarGrupo = ((Get-ADGroup -Filter "Name -like '*$hostname*'").Name)[0]
	
	# $pegaAcessoRDP = (Get-ADGroup -Identity "$selecionarGrupo" -Properties Description).Description -replace '.*RDP:([^/]+).*', '$1'
	
	# $pegaIPTS = ($pegaAcessoRDP -split ":")[0]
	
	$hostPorta = $soHost # + ":" + ($pegaAcessoRDP -split ":")[1]
	
	$usuarioAcesso = $textboxNomeUsuario.Text.ToString()
	$senhaAcesso = $textboxSenhaUsuario.Text.ToString()
	
	# comando conectar
	
	cmdkey /delete:$soHost
	Start-Process powershell -ArgumentList "-Command", "cmdkey /generic:$soHost /user:$usuarioAcesso /pass:$senhaAcesso; mstsc /v:$hostPorta"
	
}

$buttonSelecionarTodos2_Click = {
	for ($i = 0; $i -lt $ListaUsuariosTSApp2.Items.Count; $i++)
	{
		$ListaUsuariosTSApp2.SetSelected($i, $true)
	}
}
