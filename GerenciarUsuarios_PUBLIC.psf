function sincroniza()
{
	$listaValores = (Get-ChildItem -Path "C:\script\logs\arquivos_ad_permissao" -Recurse | Sort-Object -Property CreationTime -Descending).Name
	
	$ListaAtuais.Items.Clear()
	foreach ($listar in $listaValores)
	{
		$pegaUsuario = $listar -replace '(\w+) (\w+) (\w+)', '$1'
		$pegaGrupo = $listar -replace '(\w+) (\w+) (\w+)', '$2'
		$pegaTempo = $listar -replace '(\w+) (\w+) (\w+)', '$3'
		$pegaDiaLiberado_conv = (Get-ChildItem -Path "C:\script\logs\arquivos_ad_permissao\$listar").LastWriteTime
		$pegaDiaLiberado = $pegaDiaLiberado_conv.ToString("dd/MM/yyyy HH:mm")
		
		$ListaAtuais_item = New-Object System.Windows.Forms.ListViewItem($listar)
		$ListaAtuais_item.SubItems.Add($pegaTempo)
		$ListaAtuais_item.SubItems.Add($pegaUsuario)
		$ListaAtuais_item.SubItems.Add($pegaGrupo)
		$ListaAtuais_item.SubItems.Add($pegaDiaLiberado)
		$ListaAtuais.Items.Add($ListaAtuais_item)
	}
	
	<#
	for ($i = 0; $i -lt 3; $i++)
	{
		$ListaComFileiras_item = New-Object System.Windows.Forms.ListViewItem($codigo[$i])
		$ListaComFileiras_item.SubItems.Add($nome[$i])
		$ListaComFileiras_item.SubItems.Add($idade[$i])
		$ListaComFileiras_item.SubItems.Add($altura[$i])
		$ListaComFileiras.Items.Add($ListaComFileiras_item)
	}
	#>
}

