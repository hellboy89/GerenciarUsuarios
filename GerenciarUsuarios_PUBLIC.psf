                subprocess.run(['pip', 'install', package])
                print(f'{package} foi instalado com sucesso.')

    if __name__ == '__main__':
        check_and_install_packages()

verificaPacotesNecessarios()

import gspread
from oauth2client.service_account import ServiceAccountCredentials
from time import sleep
import datetime


# Set up the credentials
scope = ['https://spreadsheets.google.com/feeds', 'https://www.googleapis.com/auth/spreadsheets', 'https://www.googleapis.com/auth/drive.file', 'https://www.googleapis.com/auth/drive']
creds = ServiceAccountCredentials.from_json_keyfile_name('C:\script\LiberaPermissaoPreenchimento\_GoogleAutenticacao_NAOMEXA.json', scope)
client = gspread.authorize(creds)

# Open the Google Sheet using its name
spreadsheet = client.open('SOLICITACAO DE ACESSO AOS SERVIDORES')

# Specify the worksheet by name
worksheet_name = 'Consultores'  # Substitua pelo nome da aba desejada
worksheet = spreadsheet.worksheet(worksheet_name)

agora = datetime.datetime.now()
dataHoje = agora.strftime('%d/%m/%Y')

# Data to append
data = [f'$nomeUsuario', f'$nomeServidorGrupo', f'$nomeCliente', dataHoje, f'$periodoTempo', f'$motivoLib', f'$classificacaoAcesso', f'$responsavelExecutado', f'$dataLimite']

column_a_values = worksheet.col_values(1)
last_filled_row = len(column_a_values) + 1
worksheet.insert_row(data, last_filled_row, value_input_option='USER_ENTERED')

print('Data appended successfully to the specified worksheet!')
"@
	
	
	$codigoPlanilhaSolicitacoes = @"
def verificaPacotesNecessarios():
    import importlib
    import subprocess

    def check_and_install_packages():
        required_packages = ['gspread', 'oauth2client']
        
        for package in required_packages:
            try:
                importlib.import_module(package)
            except ImportError:
                print(f'O pacote {package} não está instalado. Instalando...')
                subprocess.run(['pip', 'install', package])
                print(f'{package} foi instalado com sucesso.')

    if __name__ == '__main__':
        check_and_install_packages()

verificaPacotesNecessarios()

import gspread
from oauth2client.service_account import ServiceAccountCredentials
from time import sleep
import datetime

# Set up the credentials
scope = ['https://spreadsheets.google.com/feeds', 'https://www.googleapis.com/auth/spreadsheets', 'https://www.googleapis.com/auth/drive.file', 'https://www.googleapis.com/auth/drive']
creds = ServiceAccountCredentials.from_json_keyfile_name('C:\script\LiberaPermissaoPreenchimento\_GoogleAutenticacao_NAOMEXA.json', scope)
client = gspread.authorize(creds)

# Open the Google Sheet using its name
spreadsheet = client.open('Controle de Acessos - Cloud')

# Specify the worksheet by name
worksheet_name = 'Controle'  # Substitua pelo nome da aba desejada
worksheet = spreadsheet.worksheet(worksheet_name)

agora = datetime.datetime.now()
dataHoje = agora.strftime('%d/%m/%Y')

# Data to append
data = [dataHoje, f'$nomeUsuario', f'Empresa', f'Chat Google', f'Liberado acesso no servidor $nomeServidorGrupo - $nomeCliente.', f'Finalizado', f'$responsavelExecutado', f'5 minutos', dataHoje]

column_a_values = worksheet.col_values(1)
last_filled_row = len(column_a_values) + 1
worksheet.insert_row(data, last_filled_row, value_input_option='USER_ENTERED')

print('Data appended successfully to the specified worksheet!')
"@
	
	Start-Job -ScriptBlock {
		Invoke-Expression -Command "python -c `"$using:codigoPlanilhaAdmin`""
		
		Invoke-Expression -Command "python -c `"$using:codigoPlanilhaSolicitacoes`""
	}
	
}

$buttonADICIONAR_Click = {
	#TODO: Place custom script here
	
	&$criaArquivosLogs
	criaPastaLog
	$ListaUsuarios.SelectedItem.ToString()
	
	$pegaValor = $ListaGrupos.SelectedItems
	
	foreach ($listar in $pegaValor)
	{
		$pegaGrupo = (Get-ADGroup -Filter { info -like $listar -and Name -like "*admin*" }).Name
		
		$usuario = $ListaUsuarios.SelectedItem.ToString()
		$servidor = $pegaGrupo
		[int32]$tempoValor = $ListaTempo.SelectedItem
		
		$verificaPermissaoExistente = Test-Path -Path "C:\script\logs\arquivos_ad_permissao\$usuario $servidor *"
		
		if ($verificaPermissaoExistente -eq $true)
		{
			$pegaNomePermissaoExistente = (Get-ChildItem -Path "C:\script\logs\arquivos_ad_permissao\$usuario $servidor *").Name
			
			$pegaDia = $pegaNomePermissaoExistente -replace '(\w+) (\w+) (\w+)', '$3'
			
			# $BarraStatus.Text = "Permissão ja existe atualmente para o $Usuario, ate o dia $pegaDia"
			# $BarraStatus.ForeColor = "Red"
			
			$preencherPlanilha = [System.Windows.Forms.MessageBox]::Show("Permissao ja liberada para o $Usuario no $servidor, ate o dia $pegaDia. Deseja preencher as planilhas?", "Confirmação", [System.Windows.Forms.MessageBoxButtons]::YesNo, [System.Windows.Forms.MessageBoxIcon]::Question)
			
			if ($preencherPlanilha -eq "Yes")
			{
				$BarraStatus.Text = "Aguarde! Preenchendo Planilhas..."
				
				preencherGooglePlan -nomeServidor $listar
				
				$BarraStatus.Text = "Permissão Adicionada: $usuario / $servidor."
			}
		}
		else
		{
			$dataHoje = Get-Date -Format "dd"
			$pegaMes = Get-Date -Format "MM"
			
			if ($tempoValor -match "HOJE" -or (0 -eq $tempoValor))
			{
				[int32]$tempo = Get-Date -Format "dd"
			}
			else
			{
				[int32]$tempo = (Get-Date).AddDays($tempoValor).ToString("dd")
				
				if ($tempo -eq (Get-Date -Format "dd"))
				{
					[int32]$tempo = (Get-Date -Day $tempo).AddDays(-1).ToString("dd")
					
					if ($tempo -eq 31)
					{
						[int32]$tempo = (Get-Date -Day $tempo).AddDays(-2).ToString("dd")
					}
				}
				
				if ($pegaMes -like "02" -and ($tempoValor -eq 30))
				{
					[int32]$tempo = (Get-Date -Day $tempo).AddDays(-4).ToString("dd")
				}
			}
			
			
			if (($usuario -match "\w") -and $servidor -and $tempo)
			{
				Add-ADPrincipalGroupMembership -Identity $usuario -MemberOf $servidor
				
				New-Item -Path "C:\script\logs\arquivos_ad_permissao\$usuario $servidor $tempo" -ItemType "File"
				
				if ($?)
				{
					$BarraStatus.Text = "Aguarde! Preenchendo Planilhas..."
					
					preencherGooglePlan -nomeServidor $listar
					
					$BarraStatus.Text = "Permissão Adicionada: $usuario / $servidor."
					
					# CRIA LOGS =============================================
					$pegarData = Get-Date -Format "dd-MM-yyyy HH:mm:ss"
					Add-Content -Path $global:diretorio -Value ($pegarData + " => " + $env:USERNAME + " => Liberou o usuario: " + $usuario + " => No grupo: $servidor" + " => Ate o dia: " + $tempo)
				}
				else
				{
					$BarraStatus.Text = "Permissão JÁ LIBERADA antes!"
				}
			}
			else
			{
				$BarraStatus.Text = "Verifique se TODOS os valores estão preenchidos!"
			}
			
		}
	}
	
	
	
	$ListaUsuarios.ClearSelected()
	$ListaGrupos.ClearSelected()
	$ListaTempo.ClearSelected()
	$textbox_buscaUsuarios.Clear()
	$textbox_buscaGrupos.Clear()
	$combobox_responsavelSetor.Text = "Responsavel"
	$textbox_motivoLib.Text = ""
	$textbox_nomeCliente.Text = ""
	$combobox_motClassificacao.Text = ""
	
	sincroniza
	
}

$buttonREMOVERPERMISSÃO_Click = {
	#TODO: Place custom script here
	$pegaDiretorio = $ListaAtuais.SelectedItems
	
	foreach ($listar in $pegaDiretorio)
	{
		$valor = $listar.Text
		
		if ($?)
		{
			$pegaUsuario = $valor -replace '(\w+) (\w+) (\w+)', '$1'
			$pegaGrupo = $valor -replace '(\w+) (\w+) (\w+)', '$2'
			$pegaTempo = $valor -replace '(\w+) (\w+) (\w+)', '$3'
			
			Remove-ADPrincipalGroupMembership -Identity $pegaUsuario -MemberOf $pegaGrupo -Confirm:$false
			
			Remove-Item -Path "C:\script\logs\arquivos_ad_permissao\$valor" -Force
			
			if ($?)
			{
				$BarraStatus.Text = "Permissão REMOVIDA, do usuário $pegaUsuario"
			}
			else
			{
				$BarraStatus.Text = "Permissão JÁ REMOVIDA antes!"
			}
		}
		else
		{
			$BarraStatus.Text = "Necessário selecionar um valor para remoção."
		}
	}
	
	sincroniza
}


