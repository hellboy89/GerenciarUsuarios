$SenhaIgualUser_Click = {
	#TODO: Place custom script here
	$Usuario = $ListaUsuariosOUs.SelectedItems
	
	# CONDICAO PREENCHER PLANILHA ================================
	
	if ([string]::IsNullOrEmpty($textboxNomeSolicitante.Text))
	{
		$BarraStatus.Text = "Precisa INFORMAR o SOLICITANTE!"
		return
	}
	
	if (($radiobuttonSolExterno.Checked -eq $false) -and ($radiobuttonSolInterno.Checked -eq $false))
	{
		$BarraStatus.Text = "Precisa INFORMAR se o SOLICITANTE e INTERNO ou EXTERNO!"
		return
	}
	
	if ($radiobuttonSolInterno.Checked)
	{
		$pegarNomeEmpresaUsuario = "Empresa"
		$formaSolicitacao = "Chat Google"
	}
	else
	{
		$pegaEmpresa = (($labelMostraEmpresa.Text) -split "-")[0]
		$pegarNomeEmpresaUsuario = ($pegaEmpresa.Substring(0, 1).ToUpper() + $pegaEmpresa.Substring(1).ToLower())
		$formaSolicitacao = "Blip"
	}
	
	$pegaEmpresaOU = (($labelMostraEmpresa.Text) -split "-")[0]
	$pegarNomeOU = ($pegaEmpresaOU.Substring(0, 1).ToUpper() + $pegaEmpresaOU.Substring(1).ToLower())
	
	# ========================================================
	
	if ($Usuario)
	{
		foreach ($listar in $Usuario)
		{
			
			$senha = ConvertTo-SecureString $listar -AsPlainText -Force
			Set-ADAccountPassword -Identity $listar -NewPassword $senha -Reset
			
			Set-ADUser -Identity $listar -ChangePasswordAtLogon $false -PasswordNeverExpires $true
			
			Set-ADUser -Identity $listar -Description "Senha - $listar"
			
			$BarraStatus.Text = "Senha resetada do $listar para $listar. E Fixada!"
			
			$DescricaoUsuario.Text = (Get-ADUser -Identity $listar -Properties Description).Description
		}
		
		preencherGooglePlan2 $textboxNomeSolicitante.Text $pegarNomeEmpresaUsuario $pegarNomeOU $formaSolicitacao
		
		limparCamposObrigatoriosSenha
	}
	else
	{
		
		$senha = ConvertTo-SecureString $global:usuarioSelecionado -AsPlainText -Force
		Set-ADAccountPassword -Identity $global:usuarioSelecionado -NewPassword $senha -Reset
		
		Set-ADUser -Identity $global:usuarioSelecionado -ChangePasswordAtLogon $false -PasswordNeverExpires $true
		
		Set-ADUser -Identity $global:usuarioSelecionado -Description "Senha - $global:usuarioSelecionado"
		
		$BarraStatus.Text = "Senha Alterada do $global:usuarioSelecionado para $global:usuarioSelecionado. E Fixada!"
		
		preencherGooglePlan2 $textboxNomeSolicitante.Text $pegarNomeEmpresaUsuario $pegarNomeOU $formaSolicitacao
		
		$DescricaoUsuario.Text = (Get-ADUser -Identity $global:usuarioSelecionado -Properties Description).Description
		
		limparCamposObrigatoriosSenha
	}
	
	& $DesbloquearUsuario
	$StatusUsuarioAD.Text = "OK"
	$FixarSenha.Checked = $false
	$DigitaSenha.Clear()
}

$buttonUsuarioLotes_Click = {
	#TODO: Place custom script here
	$nomeUsuario = $textboxUsuarioLogoffLotes.Text
	
	$verificaUsuario = Get-ADUser -Filter "sAMAccountName -eq '$nomeUsuario'"
	
	if ($verificaUsuario)
	{
		$BarraStatus.Text = "Processando, aguarde!..."
		
		logoffUserLotes $nomeUsuario
		
		$BarraStatus.Text = "Finalizado!"
	}
	else
	{
		$BarraStatus.Text = "Usuário NÃO Existe, tente novamente!"
	}
}

function logoffUserLotes($usuario)
{
	$textboxSaidaComando.Text = ""
	
	$global:username = $usuario
	
	# Importa o módulo Active Directory
	Import-Module ActiveDirectory
	
	# Obtém todos os servidores no domínio
	$servers = Get-ADComputer -Filter 'OperatingSystem -like "*Server*" -and PrimaryGroupID -ne "516"' -Property Name, OperatingSystem
	
	$servidoresLista = $servers | ForEach-Object {
		$_.Name
	}
	
	function logoffUser()
	{
		
		foreach ($listar in $servidoresLista)
		{
			
			$hostname = "$listar"
			
			$textboxSaidaComando.AppendText("Derrubando $listar" + [Environment]::NewLine)
			
			$scriptBlock = {
				param ($global:username)
				$sessions = query user | Select-String $global:username
				foreach ($session in $sessions)
				{
					$sessionID = $session -split "\s+" | Select-Object -Index 2
					logoff $sessionID
				}
			}
			
			Invoke-Command -ComputerName $hostname -ScriptBlock $scriptBlock -ArgumentList $global:username -AsJob
			
		}
		
	}
	
	logoffUser
}

$buttonComandoLotes_Click = {
	#TODO: Place custom script here
	$textboxSaidaComando.Text = ""
	$BarraStatus.Text = "Carregando, aguarde!..."
	
	$comando = $textboxComandoLotes.Text
	
	executaComandoLotes -comando $comando
	
	$BarraStatus.Text = "Finalizado!..."
}

function executaComandoLotes()
{
	param (
		[string]$comando
	)
	
	$global:scriptBlock = {
		Invoke-Expression $using:comando
	}
	
	# Importa o módulo Active Directory
	Import-Module ActiveDirectory
	
	# Obtém todos os servidores no domínio
	$servers = Get-ADComputer -Filter 'OperatingSystem -like "*Server*"' -Property Name, OperatingSystem
	
	if ($checkboxPegaAD.Checked)
	{
		$servers = Get-ADComputer -Filter 'OperatingSystem -like "*Server*"' -Property Name, OperatingSystem
	}
	else
	{
		$servers = Get-ADComputer -Filter 'OperatingSystem -like "*Server*" -and -not (primaryGroupID -eq 516)' -Property Name, OperatingSystem
	}
	
	$servidoresLista = $servers | ForEach-Object {
		$_.Name
	}
	
	function rodaComando()
	{
		foreach ($listar in $servidoresLista)
		{
			$textboxSaidaComando.AppendText("Rodando => $listar" + [Environment]::NewLine)
			
			try
			{
				$resultado = Invoke-Command -ComputerName $listar -ScriptBlock $global:scriptBlock -AsJob
			}
			catch
			{
				$textboxSaidaComando.AppendText("Erro => $_" + [Environment]::NewLine)
			}
		}
	}
	
	rodaComando
}


$buttonSenhaAleatoria_Click={
	#TODO: Place custom script here
	$Usuario = $ListaUsuariosOUs.SelectedItems
	
	# CONDICAO PREENCHER PLANILHA ================================
	
	if ([string]::IsNullOrEmpty($textboxNomeSolicitante.Text))
	{
		$BarraStatus.Text = "Precisa INFORMAR o SOLICITANTE!"
		return
	}
	
	if (($radiobuttonSolExterno.Checked -eq $false) -and ($radiobuttonSolInterno.Checked -eq $false))
	{
		$BarraStatus.Text = "Precisa INFORMAR se o SOLICITANTE e INTERNO ou EXTERNO!"
		return
	}
	
	if ($radiobuttonSolInterno.Checked)
	{
		$pegarNomeEmpresaUsuario = "Empresa"
		$formaSolicitacao = "Chat Google"
	}
	else
	{
		$pegaEmpresa = (($labelMostraEmpresa.Text) -split "-")[0]
		$pegarNomeEmpresaUsuario = ($pegaEmpresa.Substring(0, 1).ToUpper() + $pegaEmpresa.Substring(1).ToLower())
		$formaSolicitacao = "Blip"
	}
	
	$pegaEmpresaOU = (($labelMostraEmpresa.Text) -split "-")[0]
	$pegarNomeOU = ($pegaEmpresaOU.Substring(0, 1).ToUpper() + $pegaEmpresaOU.Substring(1).ToLower())
	
	# ========================================================
	
	if ($Usuario)
	{
		foreach ($listar in $Usuario)
		{
			$gerandoSenha = GerarSenhaAleatoria
			
			$senha = ConvertTo-SecureString $gerandoSenha -AsPlainText -Force
			Set-ADAccountPassword -Identity $listar -NewPassword $senha -Reset
			
			Set-ADUser -Identity $listar -ChangePasswordAtLogon $false -PasswordNeverExpires $true
			
			Set-ADUser -Identity $listar -Description "Senha - $gerandoSenha"
			
			$BarraStatus.Text = "Senha resetada do $listar para $gerandoSenha. E Fixada!"
			
			$DescricaoUsuario.Text = (Get-ADUser -Identity $listar -Properties Description).Description
		}
		
		preencherGooglePlan2 $textboxNomeSolicitante.Text $pegarNomeEmpresaUsuario $pegarNomeOU $formaSolicitacao
		
		limparCamposObrigatoriosSenha
	}
	else
	{
		$gerandoSenha = GerarSenhaAleatoria
		
		$senha = ConvertTo-SecureString $gerandoSenha -AsPlainText -Force
		Set-ADAccountPassword -Identity $global:usuarioSelecionado -NewPassword $senha -Reset
		
		Set-ADUser -Identity $global:usuarioSelecionado -ChangePasswordAtLogon $false -PasswordNeverExpires $true
		
		Set-ADUser -Identity $global:usuarioSelecionado -Description "Senha - $gerandoSenha"
		
		$BarraStatus.Text = "Senha Alterada do $global:usuarioSelecionado para $gerandoSenha. E Fixada!"
		
		preencherGooglePlan2 $textboxNomeSolicitante.Text $pegarNomeEmpresaUsuario $pegarNomeOU $formaSolicitacao
		
		$DescricaoUsuario.Text = (Get-ADUser -Identity $global:usuarioSelecionado -Properties Description).Description
		
		limparCamposObrigatoriosSenha
	}
	
	& $DesbloquearUsuario
	$StatusUsuarioAD.Text = "OK"
	$FixarSenha.Checked = $false
	$DigitaSenha.Clear()
}

function GerarSenhaAleatoria
{
	$caracteres = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789"
	$senha = ""
	for ($i = 0; $i -lt 10; $i++)
	{
		$senha += $caracteres[(Get-Random -Minimum 0 -Maximum $caracteres.Length)]
	}
	return $senha
}



