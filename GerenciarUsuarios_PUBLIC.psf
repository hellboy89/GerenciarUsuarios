$listbox_listaUsuariosSelecionados_DoubleClick = {
	#TODO: Place custom script here
	$pegaUsuario = $listbox_listaUsuariosSelecionados.SelectedItem
	
	$pegaGrupoUsers = (((Get-ADPrincipalGroupMembership -Identity $pegaUsuario | Where-Object { $_.Name -like "ts_users*" }).Name).Split("_"))[-1]
	
	$encontraHost = Get-ADComputer -Filter { OperatingSystem -Like "*Server*" } -Properties Created, Description | Where-Object { $_.Name -like "*$pegaGrupoUsers*" } | Select-Object -ExpandProperty Name
	
	$BarraStatus.Text = $encontraHost
}

$button_soLogoff_Click = {
	#TODO: Place custom script here
	$pegaUsuario = $listbox_listaUsuariosSelecionados.SelectedItems
	
	if ($pegaUsuario)
	{
		$textboxSaidaDerrubaUsuarios.Text = ""
		
		foreach ($listar in $pegaUsuario)
		{
			$BarraStatus.Text = "Derrubando USUÁRIO $listar"
			
			$pegaGrupoUsers = (Get-ADPrincipalGroupMembership -Identity $listar | Where-Object { $_.Name -like "ts_users*" }).Name
			
			foreach ($listar2 in $pegaGrupoUsers)
			{
				$pegaSoHostServidor = ($listar2.Split("_"))[-1]
				
				$encontraHost = Get-ADComputer -Filter { OperatingSystem -Like "*Server*" } -Properties Created, Description | Where-Object { $_.Name -like "*$pegaSoHostServidor*" } | Select-Object -ExpandProperty Name
				
				Invoke-Command -ComputerName $encontraHost -ScriptBlock {
					try
					{
						$idUsuarioLogado = [int](query user $using:listar | Select-Object -Skip 1 | ForEach-Object { $_.Trim() -replace "\s+", "," }).Split(",")[2]
					}
					catch
					{
						$idUsuarioLogado = [int](query user $using:listar | Select-Object -Skip 1 | ForEach-Object { $_.Trim() -replace "\s+", "," }).Split(",")[1]
					}
					
					logoff $idUsuarioLogado
					
				} -AsJob
				
				$textboxSaidaDerrubaUsuarios.AppendText("Logoff: $listar / Servidor: $encontraHost" + [Environment]::NewLine)
				
				
			}
			
			$BarraStatus.Text = "Feito Logoff em TODOS Selecionados!"
		}
	}
	else
	{
		$BarraStatus.Text = "Precisa SELECIONAR os usuários primeiro!"
	}
	
}

$button_selecionarTodos_Click = {
	#TODO: Place custom script here
	
	for ($i = 0; $i -lt $global:contadorItens; $i++)
	{
		$listbox_listaUsuariosSelecionados.SetSelected($i, $true)
	}
}

