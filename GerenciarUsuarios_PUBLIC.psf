	$listaUsuarios = (Get-ADGroupMember -Identity $pegaGrupo | Where-Object { $_.distinguishedName -notlike "*ZZ*" -and $_.distinguishedName -notlike "*esativado*" } | Sort-Object SamAccountName).SamAccountName
	
	$global:contadorItens = $listaUsuarios.Count
	
	foreach ($listar in $listaUsuarios)
	{
		$listbox_listaUsuariosSelecionados.Items.Add($listar)
